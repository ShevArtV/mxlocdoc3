<div id="mxlocdoc-app" class="mxlocdoc-app">
    <header class="mxlocdoc-topbar">
        <button class="mxlocdoc-icon-button mxlocdoc-topbar__menu" type="button" data-mxlocdoc-sidebar-open data-mxlocdoc-title="open_navigation" data-mxlocdoc-aria="open_navigation">
            <span aria-hidden="true"></span>
        </button>
        <div class="mxlocdoc-topbar__title" data-mxlocdoc-text="title"></div>
        <div class="mxlocdoc-language" data-mxlocdoc-language hidden>
            <select data-mxlocdoc-language-select></select>
        </div>
        <div class="mxlocdoc-search" role="search">
            <input type="search" data-mxlocdoc-search data-mxlocdoc-placeholder="search_hint" autocomplete="off">
            <div class="mxlocdoc-search__results" data-mxlocdoc-search-results hidden></div>
        </div>
    </header>

    <div class="mxlocdoc-shell" data-mxlocdoc-shell>
        <aside class="mxlocdoc-sidebar" data-mxlocdoc-sidebar>
            <div class="mxlocdoc-sidebar__header">
                <div class="mxlocdoc-sidebar__title" data-mxlocdoc-text="navigation"></div>
                <button class="mxlocdoc-icon-button mxlocdoc-sidebar__close" type="button" data-mxlocdoc-sidebar-close data-mxlocdoc-title="close_navigation" data-mxlocdoc-aria="close_navigation">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <nav class="mxlocdoc-nav" data-mxlocdoc-nav data-mxlocdoc-aria="navigation"></nav>
        </aside>

        <main class="mxlocdoc-document-panel">
            <div class="mxlocdoc-state" data-mxlocdoc-state data-mxlocdoc-text="loading"></div>
            <div class="mxlocdoc-breadcrumbs" data-mxlocdoc-breadcrumbs data-mxlocdoc-aria="breadcrumbs"></div>
            <article class="mxlocdoc-article" data-mxlocdoc-article></article>
            <div class="mxlocdoc-warnings" data-mxlocdoc-warnings></div>
        </main>

        <aside class="mxlocdoc-toc" data-mxlocdoc-toc data-mxlocdoc-aria="toc">
            <div class="mxlocdoc-toc__title" data-mxlocdoc-text="toc"></div>
            <nav data-mxlocdoc-toc-list></nav>
        </aside>
    </div>
</div>
